{
  "name": "voxcpm-studio-electron",
  "version": "0.2.0",
  "description": "Electron native desktop shell for VoxCPM Studio.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "build": "vite build",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "package:dir": "npm run build && electron-builder --dir",
    "package:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.3.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.openbmb.voxcpm.studio.electron",
    "productName": "VoxCPM Studio Electron",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
